{
  "name": "resumecraft",
  "productName": "Resumecraft",
  "version": "1.0.0",
  "description": "Local resume/CV builder — pick a template, fill structured sections, live preview, export an ATS-friendly PDF. Pay once, own it forever.",
  "main": "main.js",
  "author": "Ben (bensblueprints)",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "test": "node test/smoke.js",
    "dist": "electron-builder --win nsis"
  },
  "devDependencies": {
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.bensblueprints.resumecraft",
    "productName": "Resumecraft",
    "files": [
      "main.js",
      "preload.js",
      "lib/**/*",
      "renderer/**/*"
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "menuCategory": "OneTimeSuite"
    }
  }
}
